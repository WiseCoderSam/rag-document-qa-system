# SQLite is fine for local dev (zero setup). In production, point this at a
# real Postgres instance instead (e.g. your Supabase project's connection
# string, from Project Settings -> Database -> Connection string -> URI) --
# most free hosting tiers have no persistent disk, so a SQLite file gets
# wiped on every redeploy/restart.
DATABASE_URL=sqlite:///./sql_app.db
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=logs
GEMINI_API_KEY=
# Comma-separated list of origins allowed to call this API (CORS).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
