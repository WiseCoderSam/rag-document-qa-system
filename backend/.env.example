# SQLite is fine for local dev (zero setup). In production, point this at a
# real Postgres instance instead (e.g. your Supabase project's connection
# string, from Project Settings -> Database -> Connection string -> URI) --
# most free hosting tiers have no persistent disk, so a SQLite file gets
# wiped on every redeploy/restart.
DATABASE_URL=sqlite:///./sql_app.db
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=
# Storage bucket for uploaded logs/documents. Make this bucket PRIVATE in the
# Supabase dashboard (Storage -> bucket -> settings): uploads are stored as
# supabase:// references and read/deleted through the authenticated API, so
# nothing needs public access.
SUPABASE_STORAGE_BUCKET=logs
GEMINI_API_KEY=
# Comma-separated list of origins allowed to call this API (CORS).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Watches ingestion_watch/<user-id>/ for dropped .log files. Only useful when
# you have filesystem access to wherever this backend runs -- leave this on
# for local dev, set to "false" in a hosted deployment (see render.yaml).
ENABLE_WATCHER=true
# Max upload size in bytes (default 25 MB). Larger requests are rejected
# with 413 before the body is read.
#MAX_UPLOAD_BYTES=26214400
# Where per-IP rate-limit counters live. The in-process default is right for
# a single instance; point this at a shared Redis (redis://host:6379) if the
# API ever runs on multiple instances/workers so limits apply globally.
#RATE_LIMIT_STORAGE_URI=memory://
